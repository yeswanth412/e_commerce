<mxfile host="app.diagrams.net">
  <diagram name="E-Commerce ERD">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="cust" value="Customers" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="60" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="addr" value="Address" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="orders" value="Orders" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="items" value="Order_Items" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="180" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="products" value="Products" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="180" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="categories" value="Categories" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="120" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="suppliers" value="Suppliers" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="240" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="payments" value="Payments" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="shipments" value="Shipments" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="320" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="reviews" value="Reviews" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="320" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="wishlist" value="Wishlist" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="450" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="cart" value="Cart" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="450" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="cartitems" value="Cart_Items" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="450" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="employees" value="Employees" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="450" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="e1" edge="1" parent="1" source="cust" target="addr"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" edge="1" parent="1" source="cust" target="orders"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" edge="1" parent="1" source="orders" target="items"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" edge="1" parent="1" source="items" target="products"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" edge="1" parent="1" source="products" target="categories"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" edge="1" parent="1" source="products" target="suppliers"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" edge="1" parent="1" source="orders" target="payments"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" edge="1" parent="1" source="orders" target="shipments"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" edge="1" parent="1" source="cust" target="reviews"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" edge="1" parent="1" source="reviews" target="products"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" edge="1" parent="1" source="cust" target="wishlist"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e12" edge="1" parent="1" source="wishlist" target="products"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" edge="1" parent="1" source="cust" target="cart"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e14" edge="1" parent="1" source="cart" target="cartitems"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e15" edge="1" parent="1" source="cartitems" target="products"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>